# ============================================================
# Xtron Bot Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Discord OAuth2 ----------------------------------------
# Your Discord Application's Client ID (from Discord Developer Portal)
DISCORD_CLIENT_ID=1453060847789277287

# Your Discord Application's Client Secret (keep this secret!)
DISCORD_CLIENT_SECRET=svOQY4WgK-xXrEGUqkWPv1kIuX_cyjIv

# The exact redirect URI registered in your Discord App OAuth2 settings.
# Must exactly match what you set in Discord Developer Portal.
DISCORD_REDIRECT_URI=https://xtron-checklist.netlify.app/api/auth/discord/callback

# ---- JWT Session -------------------------------------------
# Generate a strong random secret: run `openssl rand -base64 64`
# Minimum 32 characters
JWT_SECRET=change-this-to-a-very-long-random-secret-minimum-32-characters

DATABASE_URL=https://x-tron-checklist-default-rtdb.asia-southeast1.firebasedatabase.app

# ---- App ---------------------------------------------------
NEXT_PUBLIC_APP_URL=https://xtron-checklist.netlify.app
